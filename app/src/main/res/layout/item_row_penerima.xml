<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvRowWarga"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hendra Mansur"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRowProgramPenerima"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Program: Bantuan Untuk Orang Kurang Mampu"
            android:textColor="#555555"
            android:textSize="13sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#EEEEEE" />

        <TextView
            android:id="@+id/tvRowKeterangan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#E8F5E9"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Layak menerima bantuan"
            android:textColor="#2E7D32"
            android:textSize="12sp"
            android:textStyle="italic" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A315E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registrasi Baru"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/etNama"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_login"
            android:hint="Nama Lengkap"
            android:paddingStart="16dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etTanggalLahir"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_login"
            android:hint="Tanggal Lahir"
            android:focusable="false"
            android:clickable="true"
            android:paddingStart="16dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jenis Kelamin:"
            android:textColor="#CCCCCC" />
        <RadioGroup
            android:id="@+id/rgGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <RadioButton android:id="@+id/rbPria" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pria" android:textColor="#FFFFFF"/>
            <RadioButton android:id="@+id/rbWanita" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wanita" android:textColor="#FFFFFF"/>
        </RadioGroup>

        <Spinner
            android:id="@+id/spAgama"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_login"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etRegUsername"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_login"
            android:hint="Username"
            android:paddingStart="16dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etRegPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_login"
            android:hint="Password"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_login"
            android:hint="Konfirmasi Password"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnSubmitRegister"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:backgroundTint="#FFFFFF"
            android:text="Daftar Sekarang"
            android:textColor="#1A315E" />

    </LinearLayout>
</ScrollView>